{
  "name": "esliph/validator",
  "description": "Uma biblioteca de validação de dados inspirada no Zod para PHP",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "validation",
    "schema",
    "validator"
  ],
  "authors": [
    {
      "name": "Dan Ruan",
      "email": "danrsaquetti@gmail.com"
    }
  ],
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "require": {
    "php": ">=8.2"
  },
  "autoload": {
    "psr-4": {
      "Esliph\\Validator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Esliph\\Validator\\Test\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  }
}
